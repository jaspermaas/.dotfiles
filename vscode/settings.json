{
  // General Settings
  "editor.accessibilitySupport": "off",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.fontSize": 16,
  "editor.guides.bracketPairs": true,
  "editor.inlineSuggest.enabled": true,
  "editor.minimap.enabled": true,
  "editor.renderWhitespace": "none",
  "editor.suggestSelection": "first",
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "window.autoDetectColorScheme": true,
  "workbench.preferredDarkColorTheme": "Dark Modern",
  "workbench.editor.empty.hint": "hidden",
  "workbench.tree.indent": 24,
  "editor.stickyScroll.enabled": false,
  "workbench.sideBar.location": "right",
  "update.showReleaseNotes": false,

  // Integrated Terminal Settings
  "terminal.integrated.fontSize": 17,
  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",

  // Copilot Settings
  "github.copilot.enable": {
    "*": true,
    "markdown": true,
    "plaintext": false,
    "scminput": false
  },
  "github.copilot.nextEditSuggestions.enabled": false,

  // Git Settings
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "always",
  "git.addAICoAuthor": "off",

  // Java Settings
  "[java]": {
    "editor.defaultFormatter": "redhat.java",
    "editor.suggest.snippetsPreventQuickSuggestions": false
  },
  "redhat.telemetry.enabled": false,

  // Python Settings
  "[python]": {
    "editor.defaultFormatter": "ms-python.autopep8",
    "editor.formatOnSave": true,
    "editor.formatOnType": false
  },
  "files.exclude": {
    "**/.classpath": true,
    "**/.factorypath": true,
    "**/.project": true,
    "**/.settings": true
  },
  "jupyter.askForKernelRestart": false,
  "notebook.lineNumbers": "on",
  "python.createEnvironment.trigger": "off",

  // Latex Settings
  "[bibtex]": {
    "editor.defaultFormatter": "James-Yu.latex-workshop",
    "editor.formatOnSave": true
  },
  "[latex]": {
    "editor.defaultFormatter": "James-Yu.latex-workshop",
    "editor.wordWrap": "on"
  },
  "latex-workshop.bibtex-fields.order": ["author", "year", "month", "title"],
  "latex-workshop.bibtex-fields.sort.enabled": true,
  "latex-workshop.bibtex-format.sort.enabled": true,
  "latex-workshop.bibtex-format.sortby": ["author", "year", "month", "title"],
  "latex-workshop.bibtex.maxFileSize": 10,
  "latex-workshop.latex.autoBuild.interval": 500,
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.recipes": [
    {
      "name": "lua",
      "tools": [
        "lualatex",
        "lualatex"
      ]
    },
    {
      "name": "Lua + BibTeX",
      "tools": [
        "lualatex",
        "biber",
        "lualatex",
        "lualatex"
      ]
    }
  ],
  "latex-workshop.latex.tools":[
    {
      "name": "lualatex",
      "command": "lualatex",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-lualatex",
        "-outdir=%OUTDIR%",
        "-synctex=0",
        "%DOC%"
      ]
    },
    {
      "name": "biber",
      "command": "biber",
      "args": [
        "%DOCFILE%"
      ],
      "env": {}
    }
  ],
  "latex-workshop.latex.autoClean.run": "onSucceeded",

  // Misc Settings
  "[elm]": {
    "editor.defaultFormatter": "elmTooling.elm-ls-vscode",
    "editor.formatOnSave": true
  },
  "prolog.executablePath": "/opt/homebrew/bin/swipl",


  // Not yet categorized settings (e.g. recently added by vscode or extensions)
}
